            }
            runColor = matrix[row][col];
            runLength = 1;
          }
        }

        if (runLength >= 5) {
          score += 3 + (runLength - 5);
        }
      }

      for (let col = 0; col < matrix.length; col += 1) {
        let runColor = matrix[0][col];
        let runLength = 1;

        for (let row = 1; row < matrix.length; row += 1) {
          if (matrix[row][col] === runColor) {
            runLength += 1;
          } else {
            if (runLength >= 5) {
              score += 3 + (runLength - 5);
            }
            runColor = matrix[row][col];
            runLength = 1;
          }
        }

        if (runLength >= 5) {
          score += 3 + (runLength - 5);
        }
      }

      return score;
    }

    function penaltyRule2(matrix) {
      let score = 0;

      for (let row = 0; row < matrix.length - 1; row += 1) {
        for (let col = 0; col < matrix.length - 1; col += 1) {
          const color = matrix[row][col];
          if (color === matrix[row][col + 1] && color === matrix[row + 1][col] && color === matrix[row + 1][col + 1]) {
            score += 3;
          }
        }
      }

      return score;
    }

    function penaltyRule3(matrix) {
      let score = 0;
      const patternA = [true, false, true, true, true, false, true, false, false, false, false];
      const patternB = [false, false, false, false, true, false, true, true, true, false, true];

      for (let row = 0; row < matrix.length; row += 1) {
        for (let col = 0; col <= matrix.length - 11; col += 1) {
          const slice = matrix[row].slice(col, col + 11);
          if (arraysMatch(slice, patternA) || arraysMatch(slice, patternB)) {
            score += 40;
          }
        }
      }

      for (let col = 0; col < matrix.length; col += 1) {
        for (let row = 0; row <= matrix.length - 11; row += 1) {
          const slice = [];
          for (let offset = 0; offset < 11; offset += 1) {
            slice.push(matrix[row + offset][col]);
          }

          if (arraysMatch(slice, patternA) || arraysMatch(slice, patternB)) {
            score += 40;
          }
        }
      }

      return score;
    }

    function arraysMatch(a, b) {
      if (a.length !== b.length) {
        return false;
      }

      for (let index = 0; index < a.length; index += 1) {
        if (Boolean(a[index]) !== Boolean(b[index])) {
          return false;
        }
      }

      return true;
    }

    function penaltyRule4(matrix) {
      let blackCount = 0;
      const totalCount = matrix.length * matrix.length;

      matrix.forEach((row) => {
        row.forEach((cell) => {
          if (cell) {
            blackCount += 1;
          }
        });
      });

      const ratio = (blackCount * 100) / totalCount;
      const deviation = Math.abs(ratio - 50) / 5;
      return Math.floor(deviation) * 10;
    }

    function generateQRCode() {
      const qr = new QRCode(document.getElementById("qrCode"), {
        text: window.location.href,
        width: 208,
        height: 208,
        margin: 2,
        colorDark: "#1f1f1f",
        colorLight: "#ffffff"
      });

      qr.clear();
      qr.makeCode(window.location.href);
    }

    function initialize() {
      const firstReview = generateUniqueReview();
      setReview(firstReview);
      generateQRCode();
    }

    generateBtn.addEventListener("click", () => {
      const nextReview = generateUniqueReview();
      setReview(nextReview);
      showToast("New review generated.");
    });

    copyBtn.addEventListener("click", () => {
      copyReview();
    });

    initialize();
  </script>
