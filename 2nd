    :root {
      --bg: #f5f5f2;
      --card: #ffffff;
      --surface: #fafafa;
      --text: #2c2c2c;
      --muted: #6d6d6d;
      --border: rgba(34, 34, 34, 0.08);
      --shadow: 0 24px 60px rgba(0, 0, 0, 0.08);
      --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.06);
      --accent: #c59d4d;
      --accent-dark: #a87f2f;
      --accent-soft: rgba(197, 157, 77, 0.14);
      --success: #1f7a4c;
      --radius-xl: 28px;
      --radius-lg: 22px;
      --radius-md: 16px;
      --radius-sm: 12px;
      --container: 1120px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      min-height: 100vh;
      overflow-x: hidden;
      color: var(--text);
      font-family: "Poppins", "Segoe UI", Arial, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(197, 157, 77, 0.12), transparent 30%),
        radial-gradient(circle at bottom right, rgba(0, 0, 0, 0.04), transparent 34%),
        linear-gradient(180deg, #fbfbf8 0%, #f5f5f2 100%);
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(0, 0, 0, 0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 0, 0, 0.02) 1px, transparent 1px);
      background-size: 34px 34px;
      mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.5), transparent 80%);
      opacity: 0.22;
    }

    .page {
      position: relative;
      z-index: 1;
      width: 100%;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 28px 18px;
    }

    .shell {
      width: min(100%, var(--container));
      display: grid;
      grid-template-columns: 1fr;
      gap: 22px;
      animation: fadeUp 0.8s ease both;
    }

    .hero {
      text-align: center;
      padding: 8px 14px 0;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.72);
      backdrop-filter: blur(10px);
      color: var(--muted);
      border-radius: 999px;
      padding: 10px 16px;
      box-shadow: var(--shadow-soft);
      font-size: 0.92rem;
      letter-spacing: 0.01em;
    }

    .hero-icon {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--accent), #efd39d);
      color: #fff;
      font-size: 1rem;
      box-shadow: 0 10px 20px rgba(197, 157, 77, 0.3);
      flex: 0 0 auto;
    }

    .hero h1 {
      margin: 18px auto 10px;
      max-width: 18ch;
      color: #222;
      font-size: clamp(2.1rem, 4.7vw, 4.3rem);
      line-height: 1.05;
      letter-spacing: -0.04em;
    }

    .hero p {
      margin: 0 auto;
      max-width: 850px;
      color: var(--muted);
      font-size: clamp(1rem, 1.8vw, 1.15rem);
      line-height: 1.75;
    }

    .panel {
      position: relative;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(34, 34, 34, 0.08);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow);
      padding: clamp(18px, 3vw, 30px);
    }

    .panel::before {
      content: "";
      position: absolute;
      inset: auto -20% -30% auto;
      width: 280px;
      height: 280px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(197, 157, 77, 0.16), transparent 68%);
      pointer-events: none;
    }

    .review-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
      align-items: stretch;
    }

    .review-card {
      position: relative;
      min-height: 460px;
      border-radius: calc(var(--radius-xl) - 4px);
      padding: clamp(20px, 3vw, 34px);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(252, 252, 250, 0.96));
      border: 1px solid rgba(34, 34, 34, 0.08);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.65);
      display: flex;
      flex-direction: column;
      gap: 18px;
      justify-content: space-between;
      width: 100%;
      transform: translateY(0);
      transition: transform 0.28s ease, box-shadow 0.28s ease;
    }

    .review-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-soft);
    }

    .review-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .review-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 14px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: #7d5b18;
      font-size: 0.84rem;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      font-weight: 700;
    }

    .review-meta {
      color: var(--muted);
      font-size: 0.92rem;
    }

    .review-text-wrap {
      position: relative;
      display: flex;
      flex: 1 1 auto;
      align-items: center;
      justify-content: center;
      padding: 8px 6px 0;
    }

    .quote-mark {
      position: absolute;
      top: -10px;
      left: 0;
      font-size: clamp(4rem, 8vw, 6.5rem);
      line-height: 1;
      color: rgba(197, 157, 77, 0.16);
      user-select: none;
      pointer-events: none;
    }

    .review-text {
      position: relative;
      margin: 0;
      width: 100%;
      max-width: 900px;
      color: #303030;
      font-size: clamp(1.1rem, 1.8vw, 1.4rem);
      line-height: 1.9;
      letter-spacing: 0.01em;
      text-align: center;
      transition: opacity 0.38s ease, transform 0.38s ease;
    }

    .review-text.is-fading {
      opacity: 0;
      transform: translateY(10px);
    }

    .review-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      align-content: stretch;
    }

    .action-card {
      border-radius: var(--radius-lg);
      background: linear-gradient(180deg, #fff, #fbfbfa);
      border: 1px solid rgba(34, 34, 34, 0.08);
      box-shadow: var(--shadow-soft);
      padding: 20px;
      height: 100%;
      display: flex;
      flex-direction: column;
    }

    .action-card h2 {
      margin: 0 0 12px;
      font-size: 1.05rem;
      color: #282828;
      letter-spacing: -0.01em;
    }

    .action-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
      font-size: 0.95rem;
    }

    .buttons {
      display: grid;
      gap: 12px;
      margin-top: 18px;
      margin-bottom: 0;
      margin-top: auto;
    }

    .btn {
      appearance: none;
      border: 0;
      cursor: pointer;
      border-radius: 16px;
      padding: 15px 18px;
      font-family: inherit;
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: 0.01em;
      transition:
        transform 0.25s ease,
        box-shadow 0.25s ease,
        background 0.25s ease,
        color 0.25s ease;
      width: 100%;
      position: relative;
      overflow: hidden;
    }

    .btn::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 20%, rgba(255, 255, 255, 0.2), transparent 80%);
      transform: translateX(-110%);
      transition: transform 0.6s ease;
    }

    .btn:hover::after {
      transform: translateX(110%);
    }

    .btn:hover {
      transform: translateY(-2px);
    }

    .btn:active {
      transform: translateY(0);
    }

    .btn-primary {
      color: #fff;
      background: linear-gradient(135deg, var(--accent-dark), #d7b46e);
      box-shadow: 0 14px 30px rgba(168, 127, 47, 0.28);
    }

    .btn-primary:hover {
      box-shadow: 0 16px 32px rgba(168, 127, 47, 0.34);
    }

    .btn-secondary {
      color: #2c2c2c;
      background: linear-gradient(180deg, #fff, #f3f0e7);
      border: 1px solid rgba(168, 127, 47, 0.22);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }

    .btn-secondary:hover {
      background: linear-gradient(180deg, #fff, #efe8d8);
    }

    .qr-wrap {
      display: flex;
      flex-direction: column;
      gap: 14px;
      align-items: center;
      justify-content: center;
      text-align: center;
      min-height: 250px;
      height: 100%;
    }

    .qr-shell {
      width: min(100%, 240px);
      padding: 16px;
      background: #fff;
      border-radius: 22px;
      border: 1px solid rgba(34, 34, 34, 0.08);
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.08);
      margin-inline: auto;
    }

    .qr-title {
      margin: 0;
      color: #2d2d2d;
      font-size: 1rem;
      font-weight: 700;
    }

    .qr-note {
      margin: 0;
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.6;
    }

    .footer {
      text-align: center;
      color: var(--muted);
      font-size: 0.92rem;
      padding: 6px 12px 0;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 20px;
      transform: translateX(-50%) translateY(20px);
      opacity: 0;
      pointer-events: none;
      z-index: 50;
      background: rgba(29, 29, 29, 0.94);
      color: #fff;
      padding: 12px 16px;
      border-radius: 999px;
      box-shadow: 0 16px 34px rgba(0, 0, 0, 0.2);
      transition: opacity 0.25s ease, transform 0.25s ease;
      font-size: 0.92rem;
      max-width: min(90vw, 560px);
      text-align: center;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(18px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 980px) {
      .review-card {
        min-height: auto;
      }

      .review-actions {
        grid-template-columns: 1fr;
      }

      .qr-wrap {
        min-height: auto;
      }
    }

    @media (max-width: 640px) {
      .page {
        padding: 16px 12px;
      }

      .shell {
        gap: 16px;
      }

      .hero {
        padding-inline: 0;
      }

      .hero-badge {
        width: 100%;
        justify-content: center;
      }

      .review-actions {
        grid-template-columns: 1fr;
      }

      .panel {
        padding: 14px;
      }

      .review-card {
        padding: 18px;
      }

      .action-card {
        padding: 18px;
      }

      .qr-shell {
        width: min(100%, 220px);
      }
    }
  </style>
</head>
